<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    RewriteBase /

    # Pasar cabeceras de auth a PHP (necesario en Hostinger shared hosting)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Bloquear acceso directo a la carpeta backend-api/ salvo a través de las reglas de abajo
    RewriteRule ^backend-api/$ - [F,L]

    # 1. Rutas de API y Sanctum → Laravel (backend-api/index.php)
    RewriteRule ^(api|sanctum)(/.*)? backend-api/index.php [L,QSA]

    # 2. Archivos y directorios que existen → servirlos directamente
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Bots de mensajería/redes sociales → Laravel para OG tags
    RewriteCond %{HTTP_USER_AGENT} (WhatsApp|Telegram|facebookexternalhit|Facebot|Twitterbot|Discordbot|Slackbot-LinkExpanding|LinkedInBot|Pinterest|Googlebot-Image|Applebot|baiduspider|SkypeUriPreview) [NC]
    RewriteCond %{REQUEST_URI} ^/(films/[0-9]+|entry/[a-z_]+/[0-9]+|profile/[^/]+|news/[0-9]+|post-reed/[0-9]+)/?$
    RewriteRule ^ backend-api/index.php [L,QSA]

    # 4. Todo lo demás (rutas de Vue Router) → Vue SPA
    RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_mime.c>
    AddType application/manifest+json  .webmanifest
    AddType text/javascript            .js
    AddType image/png                  .png
</IfModule>

<IfModule mod_headers.c>
    # HSTS: fuerza HTTPS durante 1 año incluyendo subdominios
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Evita clickjacking permitiendo enmarcado solo desde el mismo origen
    Header always set X-Frame-Options "SAMEORIGIN"

    # Evita MIME sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Referrer: origen completo en same-origin, solo origen en cross-origin
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Deshabilita explícitamente APIs del navegador que no usa la app
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"

    # CSP: reemplaza el "upgrade-insecure-requests" del servidor con una política completa
    # - script-src: propio bundle + Cloudflare Turnstile (CAPTCHA)
    # - style-src: propio CSS + Bootstrap Icons CDN + unsafe-inline para estilos de CKEditor
    # - img-src: self + TMDB + data URIs + cualquier HTTPS (avatares de usuario externos)
    # - font-src: Bootstrap Icons CDN + data URIs
    # - frame-src: Cloudflare Turnstile crea un iframe interno para el challenge
    # - worker-src: service worker (sw.js + workbox)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://image.tmdb.org https:; font-src 'self' data:; connect-src 'self'; worker-src 'self'; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'; upgrade-insecure-requests"
</IfModule>
